<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.natacion.controller.CrudController"
      prefWidth="1100" prefHeight="680"
      style="-fx-background-color: #1a1a2e;"
      spacing="20" alignment="CENTER">

    <VBox prefWidth="370" prefHeight="660" spacing="10"
          style="-fx-background-color: #16213e; -fx-background-radius: 12; -fx-padding: 20;">

        <Label text="📋 Registro de Participante"
               style="-fx-text-fill: #00d4ff; -fx-font-size: 16px; -fx-font-weight: bold;"/>

        <Label text="Cédula" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        <TextField fx:id="txtCedula" promptText="Ej: 1234567890"
                   prefHeight="30"
                   style="-fx-background-radius: 6; -fx-font-size: 12px;"/>

        <Label text="Nombre" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        <TextField fx:id="txtNombre" promptText="Nombre"
                   prefHeight="30"
                   style="-fx-background-radius: 6; -fx-font-size: 12px;"/>

        <Label text="Apellido" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        <TextField fx:id="txtApellido" promptText="Apellido"
                   prefHeight="30"
                   style="-fx-background-radius: 6; -fx-font-size: 12px;"/>

        <Label text="Edad" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        <TextField fx:id="txtEdad" promptText="Ej: 22"
                   prefHeight="30"
                   style="-fx-background-radius: 6; -fx-font-size: 12px;"/>

        <Label text="Correo" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        <TextField fx:id="txtCorreo" promptText="ejemplo@correo.com"
                   prefHeight="30"
                   style="-fx-background-radius: 6; -fx-font-size: 12px;"/>

        <Label text="Estado Civil" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        <ComboBox fx:id="cmbEstadoCivil" prefWidth="330" prefHeight="30"
                  style="-fx-background-radius: 6; -fx-font-size: 12px;"/>

        <Label text="Jornada" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        <HBox spacing="15" alignment="CENTER_LEFT">
            <RadioButton fx:id="rbMatutina" text="Matutina"
                         style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
            <RadioButton fx:id="rbVespertina" text="Vespertina"
                         style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
            <RadioButton fx:id="rbNocturna" text="Nocturna"
                         style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        </HBox>

        <Label text="Categoría" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        <ComboBox fx:id="cmbCategoria" prefWidth="330" prefHeight="30"
                  style="-fx-background-radius: 6; -fx-font-size: 12px;"/>

        <Label text="Observaciones" style="-fx-text-fill: #ffffff; -fx-font-size: 12px;"/>
        <TextArea fx:id="txtObservaciones" prefHeight="70" prefWidth="330"
                  style="-fx-background-radius: 6; -fx-font-size: 12px;"
                  wrapText="true"/>

        <Label fx:id="lblMensaje" text=""
               style="-fx-text-fill: #ff4444; -fx-font-size: 11px;"/>

        <HBox spacing="8" alignment="CENTER">
            <Button text="Guardar" onAction="#handleGuardar" prefWidth="78" prefHeight="32"
                    style="-fx-background-color: #00d4ff; -fx-text-fill: #000000; -fx-font-weight: bold; -fx-background-radius: 6;"/>
            <Button text="Actualizar" onAction="#handleActualizar" prefWidth="78" prefHeight="32"
                    style="-fx-background-color: #f4a100; -fx-text-fill: #000000; -fx-font-weight: bold; -fx-background-radius: 6;"/>
            <Button text="Eliminar" onAction="#handleEliminar" prefWidth="78" prefHeight="32"
                    style="-fx-background-color: #ff4444; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 6;"/>
            <Button text="Limpiar" onAction="#handleLimpiar" prefWidth="78" prefHeight="32"
                    style="-fx-background-color: #555555; -fx-text-fill: #ffffff; -fx-font-weight: bold; -fx-background-radius: 6;"/>
        </HBox>

    </VBox>

    <VBox prefWidth="680" prefHeight="660" spacing="10"
          style="-fx-background-color: #16213e; -fx-background-radius: 12; -fx-padding: 20;">

        <Label text="📊 Lista de Participantes"
               style="-fx-text-fill: #00d4ff; -fx-font-size: 16px; -fx-font-weight: bold;"/>

        <TableView fx:id="tablaParticipantes" prefHeight="600" prefWidth="640">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
                <TableColumn fx:id="colCedula" text="Cédula" prefWidth="90"/>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="90"/>
                <TableColumn fx:id="colApellido" text="Apellido" prefWidth="90"/>
                <TableColumn fx:id="colEdad" text="Edad" prefWidth="45"/>
                <TableColumn fx:id="colCorreo" text="Correo" prefWidth="130"/>
                <TableColumn fx:id="colEstadoCivil" text="Estado Civil" prefWidth="85"/>
                <TableColumn fx:id="colJornada" text="Jornada" prefWidth="75"/>
                <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="80"/>
            </columns>
        </TableView>

    </VBox>

</HBox>